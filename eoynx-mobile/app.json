{
  "expo": {
    "name": "Eoynx",
    "slug": "eoynx-mobile",
    "scheme": "eoynxmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-mark-icon-white-50.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logo-mark-adaptive.png",
        "monochromeImage": "./assets/logo-mark-white-adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.eoynxmobile"
    },
    "web": {
      "favicon": "./assets/logo-mark.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EOYNX to access your photos.",
          "cameraPermission": "Allow EOYNX to use your camera."
        }
      ],
      "expo-video"
    ]
  }
}
